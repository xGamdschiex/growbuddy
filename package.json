{
	"name": "growbuddy",
	"private": true,
	"version": "1.3.23",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:i18n": "node scripts/check-i18n.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"cap:sync": "npm run build && npx cap sync android",
		"cap:open": "npx cap open android",
		"apk:debug": "npm run cap:sync && cd android && ./gradlew assembleDebug",
		"apk:release": "npm run cap:sync && cd android && ./gradlew assembleRelease",
		"aab:release": "npm run cap:sync && cd android && ./gradlew bundleRelease"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@vitest/ui": "^4.1.4",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@capacitor/android": "^8.3.0",
		"@capacitor/app": "^8.1.0",
		"@capacitor/browser": "^8.0.3",
		"@capacitor/cli": "^8.3.0",
		"@capacitor/core": "^8.3.0",
		"@capacitor/haptics": "^8.0.2",
		"@capacitor/local-notifications": "^8.0.2",
		"@capacitor/splash-screen": "^8.0.1",
		"@capacitor/status-bar": "^8.0.2",
		"@supabase/supabase-js": "^2.103.0"
	}
}
